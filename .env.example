# =============================================================================
# 環境変数のテンプレート。
#   cp .env.example .env  してから値を埋めること。
# `.env` は .gitignore 済みなのでコミットされない。
# =============================================================================

# Azure Maps の主キー（サブスクリプションキー）。
# Azure Portal > Azure Maps アカウント > 認証 > 主キー から取得する。
# 未設定でもアプリは起動するが、地図タイルは表示されない。
AZURE_MAPS_SUBSCRIPTION_KEY=

# --- データアクセス (ローカル完結。通常は変更不要) ---
DATA_STORE_BACKEND=local
LOCAL_DATA_DIR=data/processed
GEOCODER_BACKEND=gsi

# --- 生成AI ---
#   LLM_BACKEND: openai | azure_openai | echo
#     openai       … OpenAI API（既定。クォータ管理が不要）
#     azure_openai … Azure OpenAI Service（デプロイ単位のクォータ割当が必要）
#     echo         … 外部通信しないスタブ（キーなしで画面確認したいとき）
LLM_BACKEND=openai

# OpenAI API
#   取得手順: https://platform.openai.com/api-keys で「Create new secret key」
#   キーは sk- で始まる。課金設定(Billing)が有効でないと 429 になる点に注意。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 互換エンドポイントを使う場合のみ変更（通常は空でよい）
OPENAI_BASE_URL=

# Azure OpenAI Service（LLM_BACKEND=azure_openai のときだけ使用）
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# AIに渡す周辺施設の検索半径(km)。広げるとトークン量と応答時間が増える
CHAT_SEARCH_RADIUS_KM=2.0
